# Copy to .env (gitignored) and fill. This is the Layer-1 FALLBACK path.
# Preferred is Infisical `run` (Layer 2) — see docs/secrets.md. Only the vars for
# the MCP servers you enable are needed. secrets.sh resolves these at launch.
#
# Which backend resolves these? Set HARNESS_SECRETS_BACKEND below.
#   env       -> values read straight from this .env file (default, current)
#   1password -> values are `op://vault/item/field` refs, resolved via `op read`
#   bitwarden -> values are Bitwarden Secrets Manager IDs, resolved via `bws`
HARNESS_SECRETS_BACKEND=env

# --- Infisical (preferred: `infisical run -- <agent>`, Layer 2) ---
# Self-hosted instance URL. The CLI reads INFISICAL_API_URL (or use --domain /
# `infisical login`). Set your real value in .env (gitignored), not here.
INFISICAL_API_URL=https://infisical.internal.example.com

# --- Kubernetes ---
KUBECONFIG=

# --- ArgoCD ---
ARGOCD_BASE_URL=
ARGOCD_API_TOKEN=

# --- Grafana ---
GRAFANA_URL=
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# --- GitHub ---
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Home Assistant ---
HA_URL=
HA_TOKEN=

# --- Context7 (docs) ---
CONTEXT7_API_KEY=

# --- Embedded / ESP-IDF ---
IDF_PATH=

# --- Nordic ---
NORDIC_API_KEY=

# --- Proxmox ---
# MCP deferred (see mcp/catalog.md) — use the proxmox-api skill for now. These
# vars are only needed if/when a proper Proxmox MCP is built.
PROXMOX_HOST=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
