# Copy to .env (gitignored) and fill. Only the vars for the MCP servers you
# actually enable are needed. secrets.sh resolves these at launch.
#
# Which backend resolves these? Set HARNESS_SECRETS_BACKEND below.
#   env       -> values read straight from this .env file (default, current)
#   1password -> values are `op://vault/item/field` refs, resolved via `op read`
#   bitwarden -> values are Bitwarden Secrets Manager IDs, resolved via `bws`
HARNESS_SECRETS_BACKEND=env

# --- Kubernetes ---
KUBECONFIG=

# --- ArgoCD ---
ARGOCD_BASE_URL=
ARGOCD_API_TOKEN=

# --- Grafana ---
GRAFANA_URL=
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# --- GitHub ---
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Home Assistant ---
HA_URL=
HA_TOKEN=

# --- Context7 (docs) ---
CONTEXT7_API_KEY=

# --- Embedded / ESP-IDF ---
IDF_PATH=

# --- Nordic ---
NORDIC_API_KEY=

# --- Proxmox (community MCP; audit first) ---
PROXMOX_HOST=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
